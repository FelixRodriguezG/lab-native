ignore-scripts=true
strict-dep-builds=true

# Evita instalar paquetes no declarados en package.json
save=true

# Fuerza versiones exactas sin rangos (sin ^ ni ~)
save-exact=true

# Usa npm ci en lugar de npm install (falla si el lockfile no cuadra)
prefer-ci=true

# Audita automáticamente al instalar
audit=true
audit-level=moderate

# Evita que paquetes lean variables de entorno sensibles
ignore-scripts=true

# Desactiva telemetría
fund=false

# Requiere que un paquete tenga al menos 24h publicado
minimum-release-age=1440